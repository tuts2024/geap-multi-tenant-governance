# Copy to .env and fill in for local dev (uvicorn auto-loads via python-dotenv
# if you add it, or export these manually / use `env $(cat .env) uvicorn ...`)

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# From agent repo's setup/05_deploy_agent.py output
AGENT_ENGINE_RESOURCE_NAME=projects/123456789/locations/us-central1/reasoningEngines/987654321

# From setup/01_enable_firebase.md
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_APP_ID=

APP_BASE_URL=http://localhost:8080
